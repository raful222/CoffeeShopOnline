@{
    ViewBag.Title = "תשלום";
}

<section class="page-hero compact-hero">
    <div><span class="eyebrow">תשלום מאובטח</span><h1>בחירת אמצעי תשלום</h1><p>התשלום בכרטיס מתבצע באתר PayPal. פרטי כרטיס לעולם אינם נשמרים באתר.</p></div>
</section>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="order-summary text-center">
            <i class="bi bi-paypal fs-1 text-primary" aria-hidden="true"></i>
            <h2 class="h4 mt-3">PayPal</h2>
            <p class="text-muted">תועברו ל-PayPal להשלמת התשלום, ולאחר מכן תחזרו לאישור ההזמנה.</p>
            @using (Html.BeginForm("PaymentWithPaypal", "Payment", FormMethod.Post))
            {
                <button type="submit" class="btn btn-coffee btn-lg w-100">המשך ל-PayPal</button>
            }
            @Html.ActionLink("חזרה לסל", "ShoppingCart", "Shopping", null, new { @class = "back-link" })
        </div>
    </div>
</div>
