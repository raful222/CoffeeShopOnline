@model IEnumerable<CoffeeShopOnline.Models.ShoppingViewModel>
@{
    ViewBag.Title = "התפריט";
    var noItemMessage = TempData["NoItem"] as string;
}

<section class="page-hero compact-hero">
    <div>
        <span class="eyebrow">טרי, מקומי ומוכן עכשיו</span>
        <h1>מה בא לכם היום?</h1>
        <p>בחרו מהתפריט, הוסיפו לסל ואנחנו נתחיל להכין.</p>
    </div>
    @Html.ActionLink("בחירת שולחן אחר", "OnlineOrder", "Home", null, new { @class = "btn btn-outline-dark" })
</section>

@if (!string.IsNullOrWhiteSpace(noItemMessage))
{
    <div class="alert alert-warning" role="alert">@noItemMessage</div>
}

@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "add-to-cart-token" }))
{
    @Html.AntiForgeryToken()
}

<div class="menu-toolbar">
    <label class="search-box">
        <i class="bi bi-search" aria-hidden="true"></i>
        <span class="visually-hidden">חיפוש בתפריט</span>
        <input id="menu-search" type="search" placeholder="חיפוש קפה, מנה או קטגוריה..." autocomplete="off" />
    </label>
</div>

<div class="menu-grid" id="menu-grid">
    @foreach (var item in Model)
    {
        var isLunchTime = DateTime.Now.Hour > 12 && DateTime.Now.Hour < 17;
        var visible = (item.Category != "עסקיות צהריים" && item.Category != "רביעי ספשיילים" && item.Category != "תפריט אירוע")
            || (item.Category == "רביעי ספשיילים" && DateTime.Now.DayOfWeek == DayOfWeek.Wednesday)
            || (isLunchTime && item.Category == "עסקיות צהריים")
            || (item.ClosedParty && item.Category == "תפריט אירוע");
        if (visible)
        {
            var promotionalPrice = (item.Promo && isLunchTime) || (!item.InOrOutTable && item.Category == "אלכוהול");
            <article class="menu-card" data-search="@((item.ItemName + " " + item.Category + " " + item.Description).ToLowerInvariant())">
                <div class="menu-card-image">
                    <img src="@Url.Content(item.ImagePath)" alt="@item.ItemName" loading="lazy" />
                    <span class="category-badge">@item.Category</span>
                    @if (item.PruductOfDay) { <span class="daily-badge"><i class="bi bi-star-fill"></i> מנת היום</span> }
                </div>
                <div class="menu-card-body">
                    <div class="d-flex justify-content-between gap-3 align-items-start">
                        <h2>@item.ItemName</h2>
                        <strong class="price">@((promotionalPrice ? item.PromoPrice : item.ItemPrice).ToString("#,##0.00 ₪"))</strong>
                    </div>
                    <p>@item.Description</p>
                    <div class="menu-card-footer">
                        <span class="popularity"><i class="bi bi-heart-fill" aria-hidden="true"></i> @item.Popular הזמנות</span>
                        @if (item.Quantity <= 0)
                        {
                            <span class="stock-out">אזל זמנית</span>
                        }
                        else
                        {
                            <button type="button" class="btn btn-coffee add-to-cart" data-item-id="@item.ItemId">
                                <i class="bi bi-plus-lg" aria-hidden="true"></i> הוספה לסל
                            </button>
                        }
                    </div>
                </div>
            </article>
        }
    }
</div>
<p id="no-results" class="empty-state d-none">לא מצאנו פריטים שמתאימים לחיפוש.</p>

@section scripts {
<script>
    (function () {
        var token = document.querySelector('#add-to-cart-token input[name="__RequestVerificationToken"]').value;
        var cards = Array.prototype.slice.call(document.querySelectorAll('.menu-card'));
        var search = document.getElementById('menu-search');

        search.addEventListener('input', function () {
            var query = search.value.trim().toLowerCase();
            var visible = 0;
            cards.forEach(function (card) {
                var matches = !query || card.getAttribute('data-search').indexOf(query) !== -1;
                card.classList.toggle('d-none', !matches);
                if (matches) visible++;
            });
            document.getElementById('no-results').classList.toggle('d-none', visible !== 0);
        });

        document.addEventListener('click', function (event) {
            var button = event.target.closest('.add-to-cart');
            if (!button) return;
            button.disabled = true;
            var body = '__RequestVerificationToken=' + encodeURIComponent(token) + '&itemId=' + encodeURIComponent(button.getAttribute('data-item-id'));
            fetch('@Url.Action("Index", "Shopping")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                body: body,
                credentials: 'same-origin'
            }).then(function (response) { return response.json(); }).then(function (result) {
                if (!result.Success) throw new Error(result.Message || 'לא ניתן להוסיף את הפריט.');
                var cart = document.getElementById('cartItem');
                if (cart) {
                    cart.setAttribute('aria-label', 'סל קניות, ' + result.Counter + ' פריטים');
                    cart.innerHTML = '<i class="bi bi-bag" aria-hidden="true"></i><span>סל</span>' +
                        (result.Counter > 0 ? '<span>(' + result.Counter + ')</span>' : '');
                }
                button.innerHTML = '<i class="bi bi-check-lg"></i> נוסף';
                window.setTimeout(function () { button.innerHTML = '<i class="bi bi-plus-lg"></i> הוספה לסל'; }, 1200);
            }).catch(function (error) {
                window.alert(error.message);
            }).then(function () { button.disabled = false; });
        });
    }());
</script>
}
