@model CoffeeShopOnline.Models.ItemViewModel

@{
    ViewBag.Title = "מוצר חדש";
}

<section class="product-editor" aria-labelledby="editor-title">
    <header class="product-editor-head">
        <a href="@Url.Action("Index")"><i class="bi bi-arrow-right" aria-hidden="true"></i> חזרה למלאי</a>
        <span class="eyebrow">הוספה לתפריט</span>
        <h1 id="editor-title">יצירת מוצר חדש</h1>
        <p>הוסיפו פרטים מדויקים ותמונה איכותית. המוצר יופיע בתפריט מיד לאחר השמירה.</p>
    </header>

    @using (Html.BeginForm("Create", "Items", FormMethod.Post, new { enctype = "multipart/form-data", @class = "product-editor-form" }))
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "לא הצלחנו לשמור את המוצר. בדקו את הפרטים המסומנים.", new { @class = "editor-validation", role = "alert" })

        <div class="product-editor-layout">
            <div class="editor-fields">
                <section class="editor-panel">
                    <div class="editor-panel-title"><span>1</span><div><h2>פרטי המוצר</h2><p>המידע שיופיע ללקוחות בתפריט.</p></div></div>
                    <div class="editor-grid">
                        <div class="editor-field editor-field-wide">
                            @Html.LabelFor(model => model.ItemName)
                            @Html.TextBoxFor(model => model.ItemName, new { autocomplete = "off", placeholder = "לדוגמה: קפוצ׳ינו איטלקי" })
                            @Html.ValidationMessageFor(model => model.ItemName, "", new { @class = "field-error" })
                        </div>
                        <div class="editor-field">
                            @Html.LabelFor(model => model.CategoryId)
                            @Html.DropDownListFor(model => model.CategoryId, Model.CategorySelectListItems, "בחרו קטגוריה")
                            @Html.ValidationMessageFor(model => model.CategoryId, "", new { @class = "field-error" })
                        </div>
                        <div class="editor-field">
                            @Html.LabelFor(model => model.ItemCode)
                            @Html.TextBoxFor(model => model.ItemCode, new { autocomplete = "off", placeholder = "אופציונלי" })
                            @Html.ValidationMessageFor(model => model.ItemCode, "", new { @class = "field-error" })
                        </div>
                        <div class="editor-field editor-field-wide">
                            @Html.LabelFor(model => model.Description)
                            @Html.TextAreaFor(model => model.Description, 4, 1, new { placeholder = "תיאור קצר ומזמין של המוצר" })
                            @Html.ValidationMessageFor(model => model.Description, "", new { @class = "field-error" })
                        </div>
                    </div>
                </section>

                <section class="editor-panel">
                    <div class="editor-panel-title"><span>2</span><div><h2>מחיר ומלאי</h2><p>מחיר עדכני וכמות זמינה להזמנה.</p></div></div>
                    <div class="editor-grid">
                        <div class="editor-field">
                            @Html.LabelFor(model => model.ItemPrice)
                            <div class="input-with-symbol">@Html.TextBoxFor(model => model.ItemPrice, new { type = "number", min = "0.01", max = "10000", step = "0.01" })<span>₪</span></div>
                            @Html.ValidationMessageFor(model => model.ItemPrice, "", new { @class = "field-error" })
                        </div>
                        <div class="editor-field">
                            @Html.LabelFor(model => model.Quantity)
                            @Html.TextBoxFor(model => model.Quantity, new { type = "number", min = "0", max = "100000", step = "1" })
                            @Html.ValidationMessageFor(model => model.Quantity, "", new { @class = "field-error" })
                        </div>
                        <div class="editor-toggle editor-field-wide">
                            @Html.CheckBoxFor(model => model.Promo)
                            <label for="Promo"><span><i class="bi bi-tag" aria-hidden="true"></i></span><b>הפעלת מחיר מבצע</b><small>המחיר המוזל יוצג לצד המחיר הרגיל.</small></label>
                        </div>
                        <div id="promoPriceField" class="editor-field editor-field-wide promo-price-field">
                            @Html.LabelFor(model => model.PromoPrice)
                            <div class="input-with-symbol">@Html.TextBoxFor(model => model.PromoPrice, new { type = "number", min = "0", max = "10000", step = "0.01" })<span>₪</span></div>
                            @Html.ValidationMessageFor(model => model.PromoPrice, "", new { @class = "field-error" })
                        </div>
                        <div class="editor-toggle editor-field-wide">
                            @Html.CheckBoxFor(model => model.ProductOfDay)
                            <label for="ProductOfDay"><span><i class="bi bi-star" aria-hidden="true"></i></span><b>סימון כמנת היום</b><small>המוצר יקבל הדגשה מיוחדת בתפריט.</small></label>
                        </div>
                    </div>
                </section>
            </div>

            <aside class="editor-media-panel">
                <div class="editor-panel-title"><span>3</span><div><h2>תמונת מוצר</h2><p>JPG, PNG או WebP עד 5MB.</p></div></div>
                <label class="image-upload" for="ImagePath">
                    <img id="imagePreview" alt="תצוגה מקדימה" hidden />
                    <span id="imagePlaceholder"><i class="bi bi-image" aria-hidden="true"></i><b>בחירת תמונה</b><small>לחצו להעלאה מהמחשב</small></span>
                </label>
                @Html.TextBoxFor(model => model.ImagePath, new { type = "file", accept = "image/jpeg,image/png,image/webp", @class = "visually-hidden" })
                @Html.ValidationMessageFor(model => model.ImagePath, "", new { @class = "field-error image-error" })
                <div class="editor-tip"><i class="bi bi-lightbulb" aria-hidden="true"></i><span><strong>טיפ לתמונה טובה</strong> רקע נקי ותאורה טבעית יעזרו למוצר להיראות מצוין בתפריט.</span></div>
            </aside>
        </div>

        <footer class="editor-actions">
            <a href="@Url.Action("Index")">ביטול</a>
            <button type="submit"><i class="bi bi-check2" aria-hidden="true"></i> שמירת המוצר</button>
        </footer>
    }
</section>

@section scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        (function () {
            var promo = document.getElementById('Promo');
            var promoField = document.getElementById('promoPriceField');
            var imageInput = document.getElementById('ImagePath');
            var preview = document.getElementById('imagePreview');
            var placeholder = document.getElementById('imagePlaceholder');
            function updatePromo() { promoField.hidden = !promo.checked; }
            promo.addEventListener('change', updatePromo);
            updatePromo();
            imageInput.addEventListener('change', function () {
                if (!imageInput.files || !imageInput.files[0]) return;
                preview.src = URL.createObjectURL(imageInput.files[0]);
                preview.hidden = false;
                placeholder.hidden = true;
            });
        }());
    </script>
}
