@model CoffeeShopOnline.Models.Item

@{
    ViewBag.Title = "הסרת " + Model.ItemName;
    var imagePath = string.IsNullOrWhiteSpace(Model.ImagePath) ? "~/assets/Layout/img/coffeeF.jpg" : Model.ImagePath;
}

<section class="delete-product-shell" aria-labelledby="delete-title">
    <a class="delete-back" href="@Url.Action("Index")"><i class="bi bi-arrow-right" aria-hidden="true"></i> חזרה למלאי</a>
    <div class="delete-product-card">
        <span class="delete-warning-icon"><i class="bi bi-exclamation-triangle" aria-hidden="true"></i></span>
        <span class="eyebrow">פעולה בלתי הפיכה</span>
        <h1 id="delete-title">הסרת מוצר מהתפריט</h1>
        <p>המוצר יוסר לצמיתות. אם הוא כבר מופיע בהיסטוריית הזמנות, המערכת תמנע את המחיקה כדי לשמור על נתונים תקינים.</p>
        <div class="delete-product-preview">
            <img src="@Url.Content(imagePath)" alt="@Model.ItemName" />
            <div><small>המוצר שנבחר</small><strong>@Model.ItemName</strong><span>@Model.Quantity יחידות במלאי · @Model.ItemPrice.ToString("#,##0.00 ₪")</span></div>
        </div>
        <div class="delete-safe-option"><i class="bi bi-info-circle" aria-hidden="true"></i><span><strong>רוצים רק להסתיר זמנית?</strong> חזרו למסך המלאי ועדכנו את הכמות ל־0. כך היסטוריית המוצר תישמר.</span></div>
        @using (Html.BeginForm("Delete", "Items", new { id = Model.ItemId }, FormMethod.Post, new { @class = "delete-product-actions" }))
        {
            @Html.AntiForgeryToken()
            <a href="@Url.Action("Index")">ביטול וחזרה</a>
            <button type="submit"><i class="bi bi-trash3" aria-hidden="true"></i> הסרת המוצר</button>
        }
    </div>
</section>
