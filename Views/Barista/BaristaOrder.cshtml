@model CoffeeShopOnline.Models.BaristaOrderViewModel.WelcomeBaristaViewModel
@{
    ViewBag.Title = "הזמנת בריסטה";
    var message = TempData["Message"] as string;
    var takenMessage = TempData["SitIstaken"] as string;
}

<section class="order-entry staff-entry">
    <div class="order-entry-copy">
        <span class="eyebrow">עמדת צוות · הזמנה חדשה</span>
        <h1>שירות מהיר, בלי לפספס פרט.</h1>
        <p>הזינו את פרטי האירוח, בחרו שולחן והוסיפו את המנות. המלאי והזמינות ייבדקו שוב לפני השליחה למטבח.</p>
        <div class="order-benefits">
            <span><i class="bi bi-shield-check"></i> בדיקת מלאי בזמן אמת</span>
            <span><i class="bi bi-grid-3x3-gap-fill"></i> סל עובד מבודד</span>
            <span><i class="bi bi-lightning-charge-fill"></i> אישור מיידי למטבח</span>
        </div>
    </div>

    <div class="reservation-card">
        <span class="eyebrow">שלב 1 מתוך 3</span>
        <h2>פרטי האירוח</h2>
        @if (!string.IsNullOrWhiteSpace(message) || !string.IsNullOrWhiteSpace(takenMessage))
        {
            <div class="alert alert-info" role="status">@(message ?? takenMessage)</div>
        }
        @using (Html.BeginForm("Table", "Barista", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

            <div class="mb-3">
                @Html.LabelFor(model => model.UserName, new { @class = "form-label" })
                @Html.TextBoxFor(model => model.UserName, new { @class = "form-control form-control-lg", maxlength = "100", autocomplete = "off", placeholder = "לדוגמה: דנה או dana@email.com" })
                <small class="form-text">אפשר להשאיר ריק עבור לקוח מזדמן.</small>
                @Html.ValidationMessageFor(model => model.UserName, "", new { @class = "text-danger" })
            </div>

            <div class="mb-4">
                @Html.LabelFor(model => model.NumberOfClient, new { @class = "form-label" })
                @Html.TextBoxFor(model => model.NumberOfClient, new { @class = "form-control form-control-lg", type = "number", min = "1", max = "12", inputmode = "numeric", placeholder = "לדוגמה: 4" })
                @Html.ValidationMessageFor(model => model.NumberOfClient, "", new { @class = "text-danger" })
            </div>

            <label class="event-option" for="ClosedParty">
                @Html.CheckBoxFor(model => model.ClosedParty)
                <span><strong>אירוע פרטי</strong><small>הצגת מנות מתפריט האירועים</small></span>
            </label>

            <button type="submit" class="btn btn-coffee btn-lg w-100 mt-4">לבחירת שולחן <i class="bi bi-arrow-left"></i></button>
        }
    </div>
</section>

@section scripts {
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
}
