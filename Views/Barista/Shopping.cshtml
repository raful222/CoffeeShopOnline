@model IEnumerable<CoffeeShopOnline.Models.ShoppingViewModel>
@{
    ViewBag.Title = "תפריט צוות";
    var noItemMessage = TempData["NoItem"] as string;
    var cartCount = ViewBag.CartCount == null ? 0 : Convert.ToInt32(ViewBag.CartCount);
    var tableNumber = ViewBag.TableNumber;
    var dinerCount = ViewBag.DinerCount;
    var customerName = ViewBag.CustomerName as string ?? "לקוח מזדמן";
}

<section class="page-hero staff-menu-hero">
    <div>
        <span class="eyebrow">עמדת צוות · שלב 3 מתוך 3</span>
        <h1>מרכיבים את ההזמנה</h1>
        <p>@customerName · שולחן @tableNumber · @dinerCount אורחים</p>
    </div>
    <div class="staff-hero-actions">
        @Html.ActionLink("שינוי שולחן", "BaristaOrder", "Barista", null, new { @class = "btn btn-outline-dark" })
        <a class="btn btn-coffee" id="baristaCartLink" href="@Url.Action("BaristaCart", "Barista")" aria-label="סל צוות, @cartCount פריטים">
            <i class="bi bi-bag-check"></i> סל צוות <span id="baristaCartCount">(@cartCount)</span>
        </a>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(noItemMessage))
{
    <div class="alert alert-warning" role="alert">@noItemMessage</div>
}
<div id="cart-feedback" class="alert d-none" role="status" aria-live="polite"></div>

@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "barista-cart-token" }))
{
    @Html.AntiForgeryToken()
}

<div class="menu-toolbar">
    <label class="search-box">
        <i class="bi bi-search" aria-hidden="true"></i>
        <span class="visually-hidden">חיפוש בתפריט הצוות</span>
        <input id="staff-menu-search" type="search" placeholder="חיפוש מנה, משקה או קטגוריה" aria-label="חיפוש בתפריט הצוות" />
    </label>
</div>

<div class="menu-grid" id="staff-menu-grid">
    @foreach (var item in Model)
    {
        var isWednesdaySpecial = item.Category == "רביעי ספשיילים" && DateTime.Now.DayOfWeek == DayOfWeek.Wednesday;
        var isLunch = item.Category == "עסקיות צהריים" && DateTime.Now.Hour > 12 && DateTime.Now.Hour < 17;
        var isEvent = item.Category == "תפריט אירוע" && item.ClosedParty;
        var isRegular = item.Category != "עסקיות צהריים" && item.Category != "רביעי ספשיילים" && item.Category != "תפריט אירוע";
        if (isRegular || isWednesdaySpecial || isLunch || isEvent)
        {
            var promotionalPrice = item.Promo && DateTime.Now.Hour > 12 && DateTime.Now.Hour < 17;
            <article class="menu-card" data-search="@((item.ItemName + " " + item.Category + " " + item.Description).ToLower())">
                <div class="menu-card-image">
                    <img src="@Url.Content(item.ImagePath)" alt="@item.ItemName" loading="lazy" />
                    <span class="category-badge">@item.Category</span>
                    @if (item.PruductOfDay) { <span class="daily-badge"><i class="bi bi-stars"></i> מנת היום</span> }
                </div>
                <div class="menu-card-body">
                    <div class="d-flex justify-content-between gap-3 align-items-start">
                        <h2>@item.ItemName</h2>
                        <strong class="price">@((promotionalPrice ? item.PromoPrice : item.ItemPrice).ToString("#,##0.00 ₪"))</strong>
                    </div>
                    <p>@item.Description</p>
                    <div class="menu-card-footer">
                        <span class="popularity"><i class="bi bi-heart-fill" aria-hidden="true"></i> @item.Popular הזמנות</span>
                        @if (item.Quantity <= 0)
                        {
                            <span class="stock-out">אזל זמנית</span>
                        }
                        else
                        {
                            <button type="button" class="btn btn-coffee staff-add-to-cart" data-item-id="@item.ItemId" aria-label="הוספת @item.ItemName לסל הצוות">
                                <i class="bi bi-plus-lg"></i> הוספה
                            </button>
                        }
                    </div>
                </div>
            </article>
        }
    }
</div>
<p id="staff-no-results" class="empty-state d-none">לא נמצאו פריטים שמתאימים לחיפוש.</p>

@section scripts {
<script>
    (function () {
        var token = document.querySelector('#barista-cart-token input[name="__RequestVerificationToken"]').value;
        var cards = Array.prototype.slice.call(document.querySelectorAll('#staff-menu-grid .menu-card'));
        var search = document.getElementById('staff-menu-search');
        var feedback = document.getElementById('cart-feedback');

        search.addEventListener('input', function () {
            var query = search.value.trim().toLowerCase();
            var visible = 0;
            cards.forEach(function (card) {
                var matches = !query || card.getAttribute('data-search').indexOf(query) !== -1;
                card.classList.toggle('d-none', !matches);
                if (matches) visible++;
            });
            document.getElementById('staff-no-results').classList.toggle('d-none', visible !== 0);
        });

        document.addEventListener('click', function (event) {
            var button = event.target.closest('.staff-add-to-cart');
            if (!button) return;
            button.disabled = true;
            var body = '__RequestVerificationToken=' + encodeURIComponent(token) + '&itemId=' + encodeURIComponent(button.getAttribute('data-item-id'));
            fetch('@Url.Action("Shopping", "Barista")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                body: body,
                credentials: 'same-origin'
            }).then(function (response) { return response.json(); }).then(function (result) {
                if (!result.Success) throw new Error(result.Message || 'לא ניתן להוסיף את הפריט.');
                document.getElementById('baristaCartCount').textContent = '(' + result.Counter + ')';
                document.getElementById('baristaCartLink').setAttribute('aria-label', 'סל צוות, ' + result.Counter + ' פריטים');
                feedback.className = 'alert alert-success';
                feedback.textContent = 'הפריט נוסף לסל הצוות.';
                button.innerHTML = '<i class="bi bi-check-lg"></i> נוסף';
                window.setTimeout(function () { button.innerHTML = '<i class="bi bi-plus-lg"></i> הוספה'; }, 1200);
            }).catch(function (error) {
                feedback.className = 'alert alert-danger';
                feedback.textContent = error.message;
            }).then(function () { button.disabled = false; });
        });
    }());
</script>
}
