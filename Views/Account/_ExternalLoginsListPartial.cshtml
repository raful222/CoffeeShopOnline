@model CoffeeShopOnline.Models.ExternalLoginListViewModel
@using Microsoft.Owin.Security
@{
    var providers = Context.GetOwinContext().Authentication.GetExternalAuthenticationTypes().ToList();
}
@if (providers.Any())
{
    <div class="auth-divider"><span>או המשיכו באמצעות</span></div>
    using (Html.BeginForm("ExternalLogin", "Account", new { ReturnUrl = Model.ReturnUrl }, FormMethod.Post, new { @class = "external-login-list" }))
    {
        @Html.AntiForgeryToken()
        foreach (AuthenticationDescription provider in providers)
        {
            <button type="submit" class="btn btn-outline-dark" name="provider" value="@provider.AuthenticationType" aria-label="כניסה באמצעות @provider.Caption">
                <i class="bi bi-google"></i> @provider.Caption
            </button>
        }
    }
}
