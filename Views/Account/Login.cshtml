@using CoffeeShopOnline.Models
@model LoginViewModel
@{
    ViewBag.Title = "כניסה";
    var returnUrl = ViewBag.ReturnUrl as string;
    var isStaffLogin = !string.IsNullOrWhiteSpace(returnUrl) && returnUrl.StartsWith("/Barista", StringComparison.OrdinalIgnoreCase);
}

<section class="auth-shell">
    <div class="auth-story">
        <a class="step-back" href="@Url.Action("OnlineOrder", "Home")"><i class="bi bi-arrow-right"></i> חזרה להזמנה</a>
        <span class="eyebrow">@(isStaffLogin ? "כניסת צוות מאובטחת" : "טוב שחזרתם")</span>
        <h1>@(isStaffLogin ? "עמדת הצוות מחכה לכם." : "הקפה הבא כבר קרוב.")</h1>
        <p>@(isStaffLogin ? "התחברו עם חשבון עובד מורשה כדי לנהל הזמנות ושולחנות." : "התחברו כדי לצבור כוכבים, לקבל הטבות ולשמור על חוויית הזמנה רציפה.")</p>
        <div class="auth-benefits">
            <span><i class="bi bi-shield-lock-fill"></i><strong>כניסה מוגנת</strong><small>נעילה אוטומטית לאחר ניסיונות כושלים</small></span>
            <span><i class="bi bi-stars"></i><strong>הטבות אישיות</strong><small>צבירת כוכבים בכל הזמנת קפה</small></span>
            <span><i class="bi bi-bag-check-fill"></i><strong>סל רציף</strong><small>הפריטים נשמרים גם אחרי התחברות</small></span>
        </div>
    </div>

    <div class="auth-card">
        <div class="auth-card-heading">
            <span class="auth-icon"><i class="bi bi-person-lock"></i></span>
            <div><span class="eyebrow">חשבון GTR</span><h2>כניסה לחשבון</h2></div>
        </div>

        @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "auth-form", role = "form" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger", role = "alert" })

            <div class="auth-field">
                @Html.LabelFor(model => model.UserName, new { @class = "form-label" })
                <div class="auth-input"><i class="bi bi-person"></i>@Html.TextBoxFor(model => model.UserName, new { @class = "form-control", autocomplete = "username", autofocus = "autofocus", placeholder = "שם המשתמש שלכם" })</div>
                @Html.ValidationMessageFor(model => model.UserName, "", new { @class = "text-danger" })
            </div>

            <div class="auth-field">
                @Html.LabelFor(model => model.Password, new { @class = "form-label" })
                <div class="auth-input"><i class="bi bi-key"></i>@Html.PasswordFor(model => model.Password, new { @class = "form-control", autocomplete = "current-password", placeholder = "הסיסמה שלכם" })</div>
                @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger" })
            </div>

            <label class="auth-check" for="RememberMe">
                @Html.CheckBoxFor(model => model.RememberMe)
                <span>זכרו אותי במכשיר הזה</span>
            </label>

            <button type="submit" class="btn btn-coffee btn-lg w-100">כניסה מאובטחת <i class="bi bi-arrow-left"></i></button>
        }

        @Html.Partial("_ExternalLoginsListPartial", new ExternalLoginListViewModel { ReturnUrl = ViewBag.ReturnUrl })
        <div class="auth-switch">עדיין אין לכם חשבון? @Html.ActionLink("הרשמה מהירה", "Register", "Account")</div>
    </div>
</section>

@section scripts {
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
}
