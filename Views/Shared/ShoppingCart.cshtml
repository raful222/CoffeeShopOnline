@model IEnumerable<CoffeeShopOnline.Models.ShoppingCartModel>
@{
    ViewBag.Title = "הסל שלי";
    var cart = Model == null ? new List<CoffeeShopOnline.Models.ShoppingCartModel>() : Model.ToList();
    var total = cart.Sum(item => item.Total);
    var message = TempData["Message"] as string;
}

<section class="page-hero compact-hero">
    <div><span class="eyebrow">כמעט סיימנו</span><h1>הסל שלי</h1><p>בדקו שהכול נראה טוב ושלחו את ההזמנה למטבח.</p></div>
</section>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-success" role="status">@message</div>
}

@if (cart.Count == 0)
{
    <div class="empty-state">
        <i class="bi bi-bag" aria-hidden="true"></i>
        <h2>הסל עדיין ריק</h2>
        <p>הקפה הבא שלכם נמצא במרחק לחיצה.</p>
        @Html.ActionLink("לתפריט", "Index", "Shopping", null, new { @class = "btn btn-coffee" })
    </div>
}
else
{
    <div class="cart-layout">
        <div class="cart-list">
            @foreach (var item in cart)
            {
                <article class="cart-item">
                    <img src="@Url.Content(item.ImagePath)" alt="@item.ItemName" />
                    <div class="cart-item-details"><h2>@item.ItemName</h2><span>כמות: @item.Quantity.ToString("#,##0") · @item.UnitPrice.ToString("#,##0.00 ₪") ליחידה</span></div>
                    <strong>@item.Total.ToString("#,##0.00 ₪")</strong>
                    @using (Html.BeginForm("RemoveFromCart", "Shopping", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.Hidden("itemId", item.ItemId)
                        <button class="icon-button" type="submit" aria-label="הסרת @item.ItemName"><i class="bi bi-trash"></i></button>
                    }
                </article>
            }
        </div>
        <aside class="order-summary">
            <span class="eyebrow">סיכום הזמנה</span>
            <div class="summary-row"><span>פריטים</span><span>@cart.Sum(item => item.Quantity).ToString("#,##0")</span></div>
            <div class="summary-row total"><span>סה״כ</span><strong>@total.ToString("#,##0.00 ₪")</strong></div>
            @using (Html.BeginForm("AddOrder", "Shopping", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-coffee btn-lg w-100">שליחת ההזמנה <i class="bi bi-arrow-left"></i></button>
            }
            @Html.ActionLink("להוסיף עוד משהו", "Index", "Shopping", null, new { @class = "back-link" })
        </aside>
    </div>
}
