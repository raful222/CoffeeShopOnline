@{
    var count = Session["CartCounter"] == null ? 0 : Convert.ToInt32(Session["CartCounter"]);
}
<a href="@Url.Action("ShoppingCart", "Shopping")" id="cartItem" class="header-action" aria-label="סל קניות, @count פריטים">
    <i class="bi bi-bag" aria-hidden="true"></i>
    <span>סל</span>
    @if (count > 0)
    {
        <span>(@count)</span>
    }
</a>
