<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Fresh coffee, food and table ordering at GTR Coffee." />
    <title>@(string.IsNullOrWhiteSpace(ViewBag.Title as string) ? "GTR Coffee" : ViewBag.Title + " | GTR Coffee")</title>
    <link href="~/assets/Layout/img/coffeeF.jpg" rel="icon" />
    <link href="https://fonts.googleapis.com/css?family=Heebo:400,500,600,700|Satisfy" rel="stylesheet" />
    <link href="~/assets/Layout/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/Layout/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/assets/Layout/css/style.css" rel="stylesheet" />
    <link href="~/Content/Site.css" rel="stylesheet" />
</head>
<body>
    <a class="skip-link" href="#main">דלג לתוכן</a>
    <div class="site-topbar">
        <div class="container d-flex justify-content-between flex-wrap gap-2">
            <span><i class="bi bi-clock" aria-hidden="true"></i> א׳–ש׳, 07:00–23:00</span>
            <a href="tel:+972086105555"><i class="bi bi-telephone" aria-hidden="true"></i> 08-610-5555</a>
        </div>
    </div>

    <header class="site-header">
        <nav class="navbar navbar-expand-lg navbar-light container" aria-label="ניווט ראשי">
            <a class="navbar-brand brand" href="@Url.Action("OnlineOrder", "Home")">GTR <span>Coffee</span></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavigation" aria-controls="mainNavigation" aria-expanded="false" aria-label="פתח תפריט">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNavigation">
                <ul class="navbar-nav me-auto align-items-lg-center">
                    <li class="nav-item">@Html.ActionLink("הזמנה", "OnlineOrder", "Home", null, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("עלינו", "About", "Home", null, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("צור קשר", "Contact", "Home", null, new { @class = "nav-link" })</li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" aria-expanded="false">ניהול</a>
                            <ul class="dropdown-menu">
                                <li>@Html.ActionLink("קטגוריות", "Index", "Categories", null, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("מוצרים", "Index", "Items", null, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("שולחנות", "Index", "RoomTables", null, new { @class = "dropdown-item" })</li>
                                <li>@Html.ActionLink("תפקידים", "Index", "Role", null, new { @class = "dropdown-item" })</li>
                            </ul>
                        </li>
                    }
                    @if (User.IsInRole("Baristas") || User.IsInRole("Admin"))
                    {
                        <li class="nav-item">@Html.ActionLink("הזמנות", "Index", "Orders", null, new { @class = "nav-link" })</li>
                        <li class="nav-item">@Html.ActionLink("הזמנת בריסטה", "BaristaOrder", "Barista", null, new { @class = "nav-link" })</li>
                    }
                </ul>
                <div class="header-actions">
                    @Html.Partial("_CartPartial")
                    @Html.Partial("_LoginPartial")
                </div>
            </div>
        </nav>
    </header>

    <main id="main" class="site-main">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="site-footer">
        <div class="container d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div><span class="brand">GTR <span>Coffee</span></span><p>קפה טרי, אוכל טוב ורגע לעצור.</p></div>
            <small>&copy; @DateTime.Now.Year GTR Coffee</small>
        </div>
    </footer>

    <script src="~/Scripts/jquery-3.6.0.min.js"></script>
    <script src="~/assets/Layout/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
