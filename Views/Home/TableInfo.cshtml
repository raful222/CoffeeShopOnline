@model IEnumerable<CoffeeShopOnline.Models.RoomTable>
@using System.Linq
@using System.Collections.Generic
@{
    ViewBag.Title = "בחירת שולחן";
    var indoorTables = Model.Where(table => table.RoomType == "InSide").OrderBy(table => table.TableNumber).ToList();
    var outdoorTables = Model.Where(table => table.RoomType == "OutSide").OrderBy(table => table.TableNumber).ToList();
    var guestCount = Session["count"] == null ? 0 : Convert.ToInt32(Session["count"]);
    var outsideIsOpen = DateTime.Now.DayOfWeek != DayOfWeek.Friday && DateTime.Now.DayOfWeek != DayOfWeek.Saturday;
    var availableCount = indoorTables.Count(table => !table.Available && table.TableSits >= guestCount) + (outsideIsOpen ? outdoorTables.Count(table => !table.Available && table.TableSits >= guestCount) : 0);
    var message = TempData["Message"] as string;
}

<div class="table-picker">
    <section class="table-picker-hero">
        <div class="table-picker-hero-copy">
            <a class="step-back" href="@Url.Action("OnlineOrder", "Home")"><i class="bi bi-arrow-right"></i> שינוי מספר האורחים</a>
            <span class="eyebrow">שלב 2 מתוך 3</span>
            <h1>איפה תרצו לשבת?</h1>
            <p>בחרו את השולחן שמתאים לכם. מיד אחר כך תעברו לתפריט ותוכלו להתחיל להזמין.</p>
            <div class="reservation-meta">
                <span><i class="bi bi-people-fill"></i> @guestCount אורחים</span>
                <span><i class="bi bi-lightning-charge-fill"></i> אישור מיידי</span>
                <span><i class="bi bi-clock-fill"></i> השולחן נשמר לשעתיים</span>
            </div>
        </div>
        <div class="availability-orb" aria-label="@availableCount שולחנות זמינים">
            <div class="availability-orb-ring">
                <strong>@availableCount</strong>
                <span>שולחנות<br />זמינים עכשיו</span>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="picker-alert" role="alert"><i class="bi bi-info-circle-fill"></i><span>@message</span></div>
    }

    <div class="picker-legend" aria-label="מקרא זמינות">
        <span><i class="legend-dot available"></i> זמין לבחירה</span>
        <span><i class="legend-dot unsuitable"></i> קטן מדי להרכב</span>
        <span><i class="legend-dot occupied"></i> תפוס כרגע</span>
        <span class="picker-hint"><i class="bi bi-cursor-fill"></i> לחצו על שולחן זמין כדי להמשיך</span>
    </div>

    @using (Html.BeginForm("CheckTable", "Home", FormMethod.Post, new { @class = "table-selection-form" }))
    {
        @Html.AntiForgeryToken()

        @RenderTableSection("בפנים", "חלל ממוזג, אווירה שקטה וקרוב לבריסטה", "bi-house-heart-fill", indoorTables, guestCount, "indoor")

        if (outsideIsOpen)
        {
            @RenderTableSection("בחוץ", "אוויר פתוח, אור טבעי והאווירה של הרחוב", "bi-brightness-high-fill", outdoorTables, guestCount, "outdoor")
        }
        else
        {
            <section class="seating-section seating-closed">
                <div class="closed-icon"><i class="bi bi-moon-stars-fill"></i></div>
                <div><span class="eyebrow">האזור החיצוני סגור היום</span><h2>נשמח לארח אתכם בפנים</h2><p>בימי שישי ושבת הישיבה בחוץ אינה זמינה. כל השולחנות הפנימיים מופיעים למעלה.</p></div>
            </section>
        }

        <aside class="selection-dock" id="selectionDock" aria-live="polite" data-state="empty">
            <div class="selection-dock-icon"><i class="bi bi-stars"></i></div>
            <div class="selection-dock-copy">
                <span class="selection-kicker">הבחירה שלכם</span>
                <strong id="selectedTableText">בחרו שולחן כדי להמשיך</strong>
                <small id="selectedTableMeta">השולחנות המומלצים מסומנים עבור @guestCount אורחים</small>
            </div>
            <button class="selection-confirm" id="selectionConfirm" type="submit" disabled>
                <span>אישור ומעבר לתפריט</span><i class="bi bi-arrow-left"></i>
            </button>
        </aside>
    }

    <div class="picker-confidence">
        <div><i class="bi bi-shield-check"></i><span><strong>בחירה בטוחה</strong><small>הזמינות נבדקת שוב לפני אישור ההזמנה</small></span></div>
        <div><i class="bi bi-arrow-repeat"></i><span><strong>אפשר לשנות</strong><small>תמיד ניתן לחזור ולבחור שולחן אחר</small></span></div>
        <div><i class="bi bi-cup-hot"></i><span><strong>מיד לתפריט</strong><small>לאחר הבחירה תעברו ישר להזמנה</small></span></div>
    </div>
</div>

@helper RenderTableSection(string title, string description, string icon, IList<CoffeeShopOnline.Models.RoomTable> tables, int guestCount, string mapType)
{
    var suitableTables = tables.Where(table => !table.Available && table.TableSits >= guestCount).OrderBy(table => table.TableSits).ThenBy(table => table.TableNumber).ToList();
    var recommendedId = suitableTables.Any() ? suitableTables.First().Id : -1;
    <section class="seating-section">
        <header class="seating-section-header">
            <div class="section-icon"><i class="bi @icon"></i></div>
            <div><span class="eyebrow">אזור ישיבה</span><h2>@title</h2><p>@description</p></div>
            <span class="section-availability">@suitableTables.Count מתאימים לכם</span>
        </header>

        <div class="seating-map seating-map-@mapType">
            <span class="venue-marker marker-primary"><i class="bi @(mapType == "indoor" ? "bi-cup-hot" : "bi-flower1")"></i> @(mapType == "indoor" ? "בר וקפה" : "גינת הקפה")</span>
            <span class="venue-marker marker-secondary"><i class="bi @(mapType == "indoor" ? "bi-window" : "bi-brightness-high")"></i> @(mapType == "indoor" ? "חלונות" : "אוויר פתוח")</span>
            <div class="table-card-grid">
            @foreach (var table in tables)
            {
                var isAvailable = !table.Available;
                var isSuitable = table.TableSits >= guestCount;
                var isRecommended = table.Id == recommendedId;
                if (isAvailable && isSuitable)
                {
                    <label class="table-card is-available @(isRecommended ? "is-recommended" : "")" aria-label="בחירת שולחן @table.TableNumber, עד @table.TableSits אורחים">
                        <input class="table-choice" type="radio" name="mine" value="@table.Id" data-table="@table.TableNumber" data-seats="@table.TableSits" data-zone="@title" required />
                        @TableCardContents(table, "available", isRecommended)
                    </label>
                }
                else
                {
                    <div class="table-card @(isAvailable ? "is-unsuitable" : "is-occupied")" aria-label="שולחן @table.TableNumber @(isAvailable ? "קטן מדי" : "תפוס")" aria-disabled="true">
                        @TableCardContents(table, isAvailable ? "unsuitable" : "occupied", false)
                    </div>
                }
            }
            </div>
        </div>
    </section>
}

@helper TableCardContents(CoffeeShopOnline.Models.RoomTable table, string status, bool recommended)
{
    var available = status == "available";
    <span class="table-card-topline">
        <span class="table-number"><small>שולחן</small>@table.TableNumber</span>
        <span class="table-status"><i class="status-pulse"></i>@(available ? "זמין" : status == "unsuitable" ? "קטן מדי" : "תפוס")</span>
    </span>
    if (recommended) { <span class="recommended-badge"><i class="bi bi-stars"></i> הבחירה המומלצת</span> }
    <span class="table-visual table-size-@(table.TableSits > 6 ? "large" : table.TableSits > 3 ? "medium" : "small")">
        <span class="table-surface"><i class="bi bi-cup-hot-fill"></i></span>
        @for (var chairIndex = 0; chairIndex < Math.Min(table.TableSits, 12); chairIndex++)
        {
            <span class="chair-slot" style="--chair-index: @chairIndex; --chair-count: @Math.Min(table.TableSits, 12);"><span class="chair-seat"></span></span>
        }
    </span>
    <span class="table-card-bottom">
        <span class="seat-count"><i class="bi bi-people"></i><strong>עד @table.TableSits</strong> אורחים</span>
        @if (available) { <span class="choose-arrow"><i class="bi bi-arrow-left"></i></span> }
        else { <span class="occupied-label">@(status == "unsuitable" ? "לא מתאים להרכב" : "לא זמין")</span> }
    </span>
}

@section scripts {
    <script>
        (function () {
            function initialiseTablePicker() {
                var choices = document.querySelectorAll('.table-choice');
                var dock = document.getElementById('selectionDock');
                var title = document.getElementById('selectedTableText');
                var meta = document.getElementById('selectedTableMeta');
                var confirm = document.getElementById('selectionConfirm');
                if (!dock || !title || !meta || !confirm) return;

                Array.prototype.forEach.call(choices, function (choice) {
                    choice.addEventListener('change', function () {
                        Array.prototype.forEach.call(document.querySelectorAll('.table-card.is-selected'), function (card) {
                            card.classList.remove('is-selected');
                        });
                        choice.parentElement.classList.add('is-selected');
                        title.textContent = 'שולחן ' + choice.getAttribute('data-table') + ' נבחר';
                        meta.textContent = choice.getAttribute('data-zone') + ' · עד ' + choice.getAttribute('data-seats') + ' אורחים';
                        dock.setAttribute('data-state', 'selected');
                        confirm.disabled = false;
                    });
                });
            }

            if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initialiseTablePicker);
            else initialiseTablePicker();
        }());
    </script>
}
